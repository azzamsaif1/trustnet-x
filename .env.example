# TrustNet X — Environment Variables
# Copy to .env and fill in values.
# Do NOT commit .env — it is gitignored.
# Do NOT commit wallet files or private keys.
# Devnet SOL has no real monetary value.

# ─── Settlement Mode ──────────────────────────────────────
# "simulated" = demo mode (no wallet needed, no Explorer link)
# "live"      = real Solana devnet transaction + Explorer proof
VITE_SETTLEMENT_MODE=simulated

# ─── Solana RPC ───────────────────────────────────────────
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── Wallet (required for live mode) ─────────────────────
# Option A — path to Solana keypair JSON (CLI only, not browser):
VITE_WALLET_PATH=

# Option B — Base58-encoded 64-byte secret key (works everywhere):
# Generate with: npx ts-node scripts/keypair-to-base58.ts ~/.config/solana/devnet-wallet.json
VITE_BUYER_KEYPAIR_B58=

# ─── Optional: LLM for natural-language reasoning ────────
# Demo works without it. Supports Venice AI, OpenAI, Anthropic.
LLM_API_KEY=
LLM_PROVIDER=venice
